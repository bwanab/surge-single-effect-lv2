@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .
@prefix modgui: <http://moddevices.com/ns/modgui#> .

<https://surge-synthesizer.github.io//plugins/Surge_XT_Reverb_1>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon.html> ;
        modgui:stylesheet <modgui/stylesheet.css> ;
        modgui:screenshot <modgui/screenshot.png> ;
        modgui:thumbnail <modgui/thumbnail.png> ;
        modgui:brand "Surge Synth Team" ;
        modgui:label "Reverb 1" ;
        modgui:model "boxy" ;
        modgui:color "blue" ;
        modgui:knob "aluminium" ;
        modgui:port [
            lv2:index 0 ;
            lv2:symbol "fx_parm_9" ;
            lv2:name "Mix" ;
        ] , [
            lv2:index 1 ;
            lv2:symbol "fx_parm_3" ;
            lv2:name "Decay" ;
        ] , [
            lv2:index 2 ;
            lv2:symbol "fx_parm_2" ;
            lv2:name "Size" ;
        ] , [
            lv2:index 3 ;
            lv2:symbol "fx_parm_7" ;
            lv2:name "Peak" ;
        ] ;
    ] .
